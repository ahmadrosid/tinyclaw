{
  "name": "tinyclaw",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "apps/platform/*", "packages/*"],
  "scripts": {
    "dev:server": "bun run apps/server/src/index.ts",
    "dev:cli": "bun run apps/cli/src/index.ts",
    "dev:telegram": "bun run --filter @tinyclaw/telegram dev",
    "dev:web": "bun run --filter @tinyclaw/web dev",
    "build": "bun run --workspaces --if-present build",
    "test": "bun run --workspaces --if-present test",
    "openapi:generate": "bun run --filter @tinyclaw/server openapi:generate",
    "dev:docs": "bun run --filter @tinyclaw/server dev:docs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
